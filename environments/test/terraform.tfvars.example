# Local laptop apply only.
#
# CI does NOT read this file — it gets every value from the `test` GitHub
# Environment's `vars` (non-sensitive) and `secrets` (sensitive). See
# .github/workflows/infra.yml for the full mapping.
#
# To apply from your laptop:
#   1) cp terraform.tfvars.example terraform.tfvars   (the real file is gitignored)
#   2) cp backend.hcl.example       backend.hcl       (also gitignored)
#   3) Fill both in with real values from AWS / your shared-services outputs
#   4) tofu init -backend-config=backend.hcl
#      tofu apply

# AWS profile is laptop-only; leave empty in CI (the OIDC role provides creds).
aws_profile = "test"
aws_region  = "us-west-1"

environment = "test"

# VPC
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-west-1a", "us-west-1b"]

# EKS
cluster_name       = "app-test"
kubernetes_version = "1.35"

# Domain
domain_name = "example.com"

# SharedServices account ID (for state backend and Route 53 access)
shared_services_account_id = "111111111111"

# Route 53 / DNS (from SharedServices tofu outputs)
route53_zone_id       = "Z1234567890ABC"
dns_manager_role_arn  = "arn:aws:iam::111111111111:role/route53-dns-manager"
cert_manager_role_arn = "arn:aws:iam::111111111111:role/route53-cert-manager"

# Argo CD
gitops_repo_url   = "https://github.com/<your-github-username>/gitops-repo.git"
slack_webhook_url = "" # Optional: Slack webhook for Argo CD deploy notifications

# Observability
observability_slack_webhook_url = "" # Optional: Grafana/Alertmanager alerts. NOT the Argo CD webhook above.
