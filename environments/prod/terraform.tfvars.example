# Local laptop apply only.
#
# CI does NOT read this file — it gets every value from the `production` GitHub
# Environment's `vars` (non-sensitive) and `secrets` (sensitive). See
# .github/workflows/infra.yml for the full mapping.
#
# To apply from your laptop (rarely needed for prod; the sanctioned path is CI):
#   1) cp terraform.tfvars.example terraform.tfvars   (the real file is gitignored)
#   2) cp backend.hcl.example       backend.hcl       (also gitignored)
#   3) Fill both in with real values from AWS / your shared-services outputs
#   4) tofu init -backend-config=backend.hcl
#      tofu apply

# AWS profile is laptop-only; leave empty in CI (the OIDC role provides creds).
aws_profile = "prod"
aws_region  = "us-west-1"

environment = "prod"

# VPC
vpc_cidr           = "10.1.0.0/16"
availability_zones = ["us-west-1a", "us-west-1b"]

# EKS
cluster_name       = "app-prod"
kubernetes_version = "1.35"

# Domain
domain_name = "yourdomain.com"

# SharedServices account ID (for state backend and Route 53 access)
shared_services_account_id = "111111111111"

# Route 53 / DNS (from SharedServices tofu outputs)
route53_zone_id       = "Z1234567890ABC"
dns_manager_role_arn  = "arn:aws:iam::111111111111:role/route53-dns-manager"
cert_manager_role_arn = "arn:aws:iam::111111111111:role/route53-cert-manager"

# Argo CD
gitops_repo_url   = "https://github.com/<your-github-username>/gitops-repo.git"
slack_webhook_url = ""

# Observability
observability_slack_webhook_url = "" # Optional: Grafana/Alertmanager alerts. NOT the Argo CD webhook above.
healthchecks_ping_url = "" # Optional: healthchecks.io ping URL (Phase 4 dead-man's switch).

# AWS DevOps Agent (see devops-agent.tf; rollout steps in the Observability
# doc "AWS DevOps Agent"). Off by default — nothing is created until enabled.
devops_agent_enabled          = false
devops_agent_region           = "us-west-2" # not us-west-1: DevOps Agent isn't offered there
devops_agent_idc_instance_arn = ""          # aws sso-admin list-instances → InstanceArn (required when enabled)

# Slack — fill these AFTER the one-time console OAuth registration (step 2 of
# the rollout); leave empty until then and the Slack wiring is skipped.
devops_agent_slack_service_id     = "" # aws devops-agent list-services → serviceType "slack"
devops_agent_slack_workspace_id   = "" # T…
devops_agent_slack_workspace_name = ""
devops_agent_slack_channel_id     = "" # C… — this environment's channel, e.g. #cg-alerts-prod
devops_agent_slack_channel_name   = "" # e.g. cg-alerts-prod
