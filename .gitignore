# OpenTofu
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
.terraform/
# Each ENVIRONMENT's .terraform.lock.hcl is committed (see
# environments/*/.terraform.lock.hcl): CI runs `tofu init` separately for the
# plan and apply jobs on different runners, so a committed lock pins identical
# provider versions across the two. Move it deliberately with
# `tofu init -upgrade`. Lockfiles under modules/ are just artifacts of init-ing
# a child module directly — keep those ignored.
modules/**/.terraform.lock.hcl
*.tfplan
crash.log
crash.*.log

# Actual tfvars (contain account-specific values)
terraform.tfvars

# Keep the example files
!terraform.tfvars.example

# Local-only backend config for laptop applies (CI writes its own at runtime)
backend.hcl

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
